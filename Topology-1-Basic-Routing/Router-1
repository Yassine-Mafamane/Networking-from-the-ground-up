
# Router-1 network configuration 
# Interface eth0 is connected to host-1 (eth0)
# Interface eth1 is connected to Router-2 (eth1) 
# eth0 : IP: 192.168.0.1/30
# eth1 : IP: 192.168.0.9/30 

auto eth0
iface eth0 inet static
	address 192.168.0.1
	netmask 255.255.255.252

auto eth1
iface eth1 inet static
	address 192.168.0.9
	netmask 255.255.255.252
	up ip route add 192.168.0.4/30 via 192.168.0.10

