
# Router-2 network configuration 
# Interface eth0 is connected to host-2 (eth0)
# Interface eth1 is connected to Router-1 (eth1) 
# eth0 : IP: 192.168.0.5/30
# eth1 : IP: 192.168.0.10/30 

auto eth0
iface eth0 inet static
	address 192.168.0.5
	netmask 255.255.255.252

auto eth1
iface eth1 inet static
	address 192.168.0.10
	netmask 255.255.255.252
	up ip route add 192.168.0.0/30 via 192.168.0.9

