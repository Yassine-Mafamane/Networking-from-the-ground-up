
# Router-1 network configuration 
# Interface eth0 is connected to Switch-1
# Interface eth1 is connected to Router-2 (eth1) 
# eth0 : IP: 192.168.0.1/28
# eth1 : IP: 172.16.0.1/30

auto eth0
iface eth0 inet static
	address 192.168.0.1
	netmask 255.255.255.240

auto eth1
iface eth1 inet static
	address 172.16.0.1
	netmask 255.255.255.252
	up ip route add 10.0.0.0/30 via 172.16.0.2

