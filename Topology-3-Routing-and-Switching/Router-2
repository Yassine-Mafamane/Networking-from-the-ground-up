
# Router-2 network configuration 
# Interface eth0 is connected to Webserver
# Interface eth1 is connected to Router-1 (eth1) 
# eth0 : IP: 10.0.0.1/30
# eth1 : IP: 172.16.0.2/30

auto eth0
iface eth0 inet static
	address 10.0.0.1
	netmask 255.255.255.252

auto eth1
iface eth1 inet static
	address 172.16.0.2
	netmask 255.255.255.252
	up ip route add 192.168.0.0/28 via 172.16.0.1

