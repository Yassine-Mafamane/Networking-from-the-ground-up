# VTEP-1 network configuration 
# Interface eth0 is connected to host-1 (eth0) 
# Interface eth1 is connected to Switch (eth1) 
# eth1 : IP: 10.0.0.1/30 

auto eth1 
iface eth1 inet static 
	address 10.0.0.1
	netmask 255.255.255.252 
	up ip link add vxlan10 type vxlan id 10 remote 10.0.0.2 local 10.0.0.1 dstport 4789 dev eth1 
	up ip link add br0 type bridge 
	up ip link set vxlan10 master br0 
	up ip link set eth0 master br0 
	up ip link set vxlan10 up 
	up ip link set br0 up
	up bridge fdb append 00:00:00:00:00:00 dev vxlan10 dst 10.0.0.2