# Router network configuration
# Interface eth0 is connected to Switch1 (trunk port, carries VLAN 10, 20, 30)
# eth0.10 : IP: 192.168.10.1/28 (gateway for VLAN 10 - HR)
# eth0.20 : IP: 192.168.20.1/28 (gateway for VLAN 20 - Engineering)
# eth0.30 : IP: 192.168.30.1/28 (gateway for VLAN 30 - Sales)

auto eth0
iface eth0 inet manual
	up ip link set eth0 up
	up ip link add link eth0 name eth0.10 type vlan id 10
	up ip addr add 192.168.10.1/28 dev eth0.10
	up ip link set eth0.10 up
	up ip link add link eth0 name eth0.20 type vlan id 20
	up ip addr add 192.168.20.1/28 dev eth0.20
	up ip link set eth0.20 up
	up ip link add link eth0 name eth0.30 type vlan id 30
	up ip addr add 192.168.30.1/28 dev eth0.30
	up ip link set eth0.30 up